# SlipPilot — Production Environment
# Copy this to .env and fill in real values before deploying.
# Never commit .env to git.

# Required: tells the server to run in production mode (blocks all admin/dev routes)
NODE_ENV=production

# Port the server listens on (cPanel Passenger usually sets this automatically)
PORT=3000

# ── Support email (SMTP) ──
# All support form submissions are emailed to SUPPORT_EMAIL in production.

SMTP_HOST=mail.slippilot.com.ng
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@slippilot.com.ng
SMTP_PASS=your_smtp_password

# The address that receives support tickets
SUPPORT_EMAIL=support@slippilot.com.ng

# The From address on outgoing support emails
FROM_EMAIL=SlipPilot <noreply@slippilot.com.ng>

# ── Not needed in production ──
# ADMIN_PASSWORD — no admin panel exists in production (/admin returns 404)
# SESSION_SECRET — no routes create sessions in production
