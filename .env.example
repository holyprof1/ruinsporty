# SlipPilot — Production Environment
# Copy this to .env and fill in real values before deploying.
# Never commit .env to git.

# Required: tells the server to run in production mode (gates all dev/admin routes)
NODE_ENV=production

# Port the server listens on (cPanel Passenger usually sets this automatically)
PORT=3000

# Admin password — protects all /api/admin/* and admin-only routes
ADMIN_PASSWORD=change_me_before_deploy

# Session secret — any long random string
SESSION_SECRET=change_me_before_deploy

# ── Support email (SMTP) ──
# All support form submissions are emailed instead of saved to a file in production.

SMTP_HOST=mail.slippilot.com.ng
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@slippilot.com.ng
SMTP_PASS=your_smtp_password

# The address that receives support tickets
SUPPORT_EMAIL=support@slippilot.com.ng

# The From address on outgoing support emails
FROM_EMAIL=SlipPilot <noreply@slippilot.com.ng>
